# Адреса, которые встречаются не более чем в двух логах
# (все адреса минус те, что есть везде)
dept1 = input("Первый: ")
dept2 = input("Второй: ")
dept3 = input("Третий: ")

set1 = set(dept1.split())
set2 = set(dept2.split())
set3 = set(dept3.split())

# Все ID от 0 до 10
all_ids = set(str(i) for i in range(11))

# ID, которые есть хотя бы в одном отделе
present = set1 | set2 | set3

# Призраки — кто не пришёл ни в один отдел
ghosts = all_ids - present

# Вывод по возрастанию
sorted_ghosts = sorted(ghosts, key=int)

for g in sorted_ghosts:
    print(g)
